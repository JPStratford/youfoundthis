---
interface Sighting {
  id: number;
  location: string;
  lat: number | null;
  lng: number | null;
}

interface Props {
  sightings: Sighting[];
  originLat?: number | null;
  originLng?: number | null;
  originLabel?: string | null;
}

const { sightings, originLat, originLng, originLabel } = Astro.props;
const mapped = sightings.filter(s => s.lat && s.lng);
const hasOrigin = originLat != null && originLng != null;
---

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<div id="journey-map"></div>

<script define:vars={{ mapped, originLat, originLng, originLabel, hasOrigin }}>
  function initMap() {
    if (typeof L === 'undefined') {
      setTimeout(initMap, 100);
      return;
    }

    const map = L.map('journey-map', {
      zoomControl: true,
      scrollWheelZoom: false,
    });

    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      attribution: '© OpenStreetMap contributors © CARTO',
      maxZoom: 19,
    }).addTo(map);

    const allCoords = [];

    if (hasOrigin) {
      allCoords.push([originLat, originLng]);
      L.circleMarker([originLat, originLng], {
        radius: 5,
        fillColor: '#f7f4ef',
        color: '#7a4a2e',
        weight: 1.5,
        fillOpacity: 1,
      }).addTo(map).bindPopup(
        `<span style="font-family: 'IM Fell English', Georgia, serif; font-size: 14px;">${originLabel || 'Left here'}</span>`
      );
    }

    const sightingCoords = mapped.map(s => [s.lat, s.lng]);
    allCoords.push(...sightingCoords);

    if (allCoords.length > 1) {
      L.polyline(allCoords, {
        color: '#7a4a2e',
        weight: 1.5,
        opacity: 0.6,
        dashArray: '4 6',
      }).addTo(map);
    }

    mapped.forEach((s, i) => {
      const isLast = i === mapped.length - 1;
      L.circleMarker([s.lat, s.lng], {
        radius: 5,
        fillColor: isLast ? '#7a4a2e' : '#f7f4ef',
        color: '#7a4a2e',
        weight: 1.5,
        fillOpacity: 1,
      }).addTo(map).bindPopup(
        `<span style="font-family: 'IM Fell English', Georgia, serif; font-size: 14px;">${s.location}</span>`
      );
    });

    if (allCoords.length > 1) {
      map.fitBounds(allCoords, { padding: [32, 32] });
    } else if (allCoords.length === 1) {
      map.setView(allCoords[0], 10);
    }
  }

  document.addEventListener('DOMContentLoaded', initMap);
</script>

<style>
  #journey-map {
    width: 100%;
    height: 280px;
    border-radius: 6px;
    border: 0.5px solid var(--divider);
    margin-bottom: 32px;
    background: var(--bg);
  }
</style>