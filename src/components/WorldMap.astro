---
interface Sighting {
  lat: number;
  lng: number;
  location: string;
  note_id: number;
}

interface Props {
  sightings: Sighting[];
}

const { sightings } = Astro.props;
---

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<div id="world-map"></div>

<script define:vars={{ sightings }}>
  function initMap() {
    if (typeof L === 'undefined') {
      setTimeout(initMap, 100);
      return;
    }

    const map = L.map('world-map', {
      zoomControl: false,
      scrollWheelZoom: false,
      dragging: false,
      doubleClickZoom: false,
      boxZoom: false,
      keyboard: false,
      attributionControl: false,
    });

    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      maxZoom: 19,
    }).addTo(map);

    const coords = sightings.map(s => [s.lat, s.lng]);

    if (coords.length > 1) {
      L.polyline(coords, {
        color: '#7a4a2e',
        weight: 1,
        opacity: 0.5,
        dashArray: '4 6',
      }).addTo(map);
    }

    sightings.forEach((s) => {
      L.circleMarker([s.lat, s.lng], {
        radius: 4,
        fillColor: '#7a4a2e',
        color: '#7a4a2e',
        weight: 1.5,
        fillOpacity: 1,
      }).addTo(map).bindPopup(
        `<span style="font-family: 'IM Fell English', Georgia, serif; font-size: 13px;">${s.location} · note ${s.note_id}</span>`
      );
    });

    if (coords.length > 1) {
      map.fitBounds(coords, { padding: [40, 40] });
    } else if (coords.length === 1) {
      map.setView(coords[0], 5);
    } else {
      map.setView([20, 0], 2);
    }
  }

  document.addEventListener('DOMContentLoaded', initMap);
</script>

<style>
  #world-map {
    width: 100%;
    height: 320px;
    border-radius: 6px;
    border: 0.5px solid var(--divider);
    background: var(--bg);
  }
</style>